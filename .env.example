# Atlas Vox Configuration
# Copy to .env and fill in required values for your deployment

# ═══════════════════════════════════════════════════════════════════════════════
# Core Application Settings
# ═══════════════════════════════════════════════════════════════════════════════

# Application name and environment
APP_NAME=atlas-vox
APP_ENV=development
# Set to 'production' when deploying

# Debug mode (set to false in production)
DEBUG=true

# Logging configuration
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json
# Options: json (structured), text (human-readable)

# ═══════════════════════════════════════════════════════════════════════════════
# Server Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# Host and port for the backend API server
HOST=0.0.0.0
PORT=8000

# CORS origins (comma-separated URLs that can access the API)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:3100"]

# Docker port mappings (used by docker-compose)
BACKEND_PORT=8100
FRONTEND_PORT=3100

# ═══════════════════════════════════════════════════════════════════════════════
# Database Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# SQLite (default) — just works, no setup needed, good for development/homelab
DATABASE_URL=sqlite+aiosqlite:///./atlas_vox.db

# PostgreSQL (production) — uncomment and configure for production deployments
# DATABASE_URL=postgresql+asyncpg://atlas_vox:your_password@localhost:5432/atlas_vox
# For Docker: DATABASE_URL=postgresql+asyncpg://atlas_vox:${POSTGRES_PASSWORD}@atlas-vox-postgres:5432/atlas_vox

# PostgreSQL password for Docker compose
POSTGRES_PASSWORD=atlas-vox-pg

# ═══════════════════════════════════════════════════════════════════════════════
# Authentication & Security
# ═══════════════════════════════════════════════════════════════════════════════

# Set to true for single-user/homelab mode (no login required)
AUTH_DISABLED=true

# JWT configuration (required even if AUTH_DISABLED=true for API keys)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-in-production-with-32-random-characters
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ═══════════════════════════════════════════════════════════════════════════════
# Redis Configuration (Task Queue)
# ═══════════════════════════════════════════════════════════════════════════════

# Redis URL for Celery task queue (uses db1 to avoid collision with other apps)
REDIS_URL=redis://localhost:6379/1

# Redis password for Docker compose
REDIS_PASSWORD=atlas-vox-redis

# For Docker: REDIS_URL=redis://:${REDIS_PASSWORD}@atlas-vox-redis:6379/1

# ═══════════════════════════════════════════════════════════════════════════════
# Storage Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# Local storage path for audio files, models, and outputs
STORAGE_PATH=./storage

# ═══════════════════════════════════════════════════════════════════════════════
# GPU Worker Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# GPU service URL for offloading GPU-intensive TTS providers
GPU_SERVICE_URL=http://localhost:8200
# For Docker: GPU_SERVICE_URL=http://host.docker.internal:8200

# Hugging Face cache directory (for downloading models)
HF_HOME=~/.cache/huggingface

# ═══════════════════════════════════════════════════════════════════════════════
# Cloud TTS Providers
# ═══════════════════════════════════════════════════════════════════════════════

# ElevenLabs (Cloud) — premium voice cloning service
ELEVENLABS_API_KEY=
# Get your API key from https://elevenlabs.io/
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Options: eleven_multilingual_v2, eleven_turbo_v2

# Azure AI Speech (Cloud) — Microsoft's speech service
AZURE_SPEECH_KEY=
# Get from Azure Portal > Cognitive Services > Speech
AZURE_SPEECH_REGION=eastus
# Azure region where your Speech service is deployed

# ═══════════════════════════════════════════════════════════════════════════════
# Local TTS Providers (GPU Configurable)
# ═══════════════════════════════════════════════════════════════════════════════

# Coqui XTTS v2 — Voice cloning from 6 seconds of audio
COQUI_XTTS_GPU_MODE=host_cpu
# Options: docker_gpu (GPU container), host_cpu (CPU only), auto (detect)

# StyleTTS2 — Zero-shot voice synthesis with style diffusion
STYLETTS2_GPU_MODE=host_cpu

# CosyVoice — Multilingual voice synthesis with streaming support
COSYVOICE_GPU_MODE=host_cpu

# Dia — Dialogue-focused TTS (1.6B parameters)
DIA_GPU_MODE=host_cpu

# Dia2 — Streaming dialogue TTS (2B parameters)
DIA2_GPU_MODE=host_cpu

# ═══════════════════════════════════════════════════════════════════════════════
# Local TTS Providers (CPU Only)
# ═══════════════════════════════════════════════════════════════════════════════

# Kokoro — Lightweight CPU-based TTS with 54 voices (default provider)
KOKORO_ENABLED=true

# Piper — ONNX-based neural TTS (compatible with Home Assistant)
PIPER_ENABLED=true
PIPER_MODEL_PATH=./storage/models/piper

# ═══════════════════════════════════════════════════════════════════════════════
# Development & Testing
# ═══════════════════════════════════════════════════════════════════════════════

# Enable development features (auto-reload, debug endpoints, etc.)
DEV_MODE=false

# Test database (SQLite in-memory for tests)
TEST_DATABASE_URL=sqlite+aiosqlite:///:memory:

# ═══════════════════════════════════════════════════════════════════════════════
# Performance & Monitoring
# ═══════════════════════════════════════════════════════════════════════════════

# Rate limiting (requests per minute)
RATE_LIMIT_REQUESTS=1000

# Celery worker concurrency
CELERY_WORKER_CONCURRENCY=2

# Maximum file upload size (bytes)
MAX_UPLOAD_SIZE=52428800

# Request timeout (seconds)
REQUEST_TIMEOUT=300

# ═══════════════════════════════════════════════════════════════════════════════
# Docker Compose Overrides
# ═══════════════════════════════════════════════════════════════════════════════

# Memory limits for services (Docker only)
# BACKEND_MEMORY_LIMIT=4G
# FRONTEND_MEMORY_LIMIT=256M
# POSTGRES_MEMORY_LIMIT=512M
# REDIS_MEMORY_LIMIT=512M
# WORKER_MEMORY_LIMIT=8G

# Additional Docker environment variables
# DOCKER_BUILDKIT=1
# COMPOSE_DOCKER_CLI_BUILD=1

# ═══════════════════════════════════════════════════════════════════════════════
# Quick Setup Examples
# ═══════════════════════════════════════════════════════════════════════════════

# For local development (SQLite + CPU providers):
# AUTH_DISABLED=true
# DATABASE_URL=sqlite+aiosqlite:///./atlas_vox.db
# REDIS_URL=redis://localhost:6379/1
# All GPU_MODE variables: host_cpu

# For production (PostgreSQL + auth + mixed providers):
# AUTH_DISABLED=false
# DATABASE_URL=postgresql+asyncpg://atlas_vox:secure_password@localhost:5432/atlas_vox
# JWT_SECRET_KEY=your_32_character_secret_key_here
# GPU providers: docker_gpu or host_cpu based on hardware

# For Docker deployment:
# Use the docker-compose.yml environment variables
# Set POSTGRES_PASSWORD and REDIS_PASSWORD for security
