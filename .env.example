# Atlas Vox Configuration
# Copy to .env and fill in required values

# ─── Application ───
APP_NAME=atlas-vox
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── Server ───
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── Database ───
# SQLite (default) — just works, no setup needed
DATABASE_URL=sqlite+aiosqlite:///./atlas_vox.db
# PostgreSQL (optional) — uncomment for production
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/atlas_vox

# ─── Authentication ───
# Set to true for single-user/homelab (no auth required)
AUTH_DISABLED=true
# JWT secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── Redis (for Celery task queue) ───
# Uses db1 to avoid collision with ATLAS (db0)
REDIS_URL=redis://localhost:6379/1

# ─── Storage ───
STORAGE_PATH=./storage

# ─── Provider: ElevenLabs (Cloud) ───
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ─── Provider: Azure AI Speech (Cloud) ───
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# ─── Provider: Coqui XTTS v2 (Local) ───
COQUI_XTTS_GPU_MODE=host_cpu
# Options: docker_gpu, host_cpu, auto

# ─── Provider: StyleTTS2 (Local) ───
STYLETTS2_GPU_MODE=host_cpu

# ─── Provider: CosyVoice (Local) ───
COSYVOICE_GPU_MODE=host_cpu

# ─── Provider: Kokoro (Local, CPU-only) ───
KOKORO_ENABLED=true

# ─── Provider: Piper (Local, CPU-only) ───
PIPER_ENABLED=true
PIPER_MODEL_PATH=./storage/models/piper

# ─── Provider: Dia (Local) ───
DIA_GPU_MODE=host_cpu

# ─── Provider: Dia2 (Local) ───
DIA2_GPU_MODE=host_cpu
