# Atlas Vox — Docker Compose environment
# Change these if the defaults conflict with services on your host
BACKEND_PORT=8100
FRONTEND_PORT=3100

# HTTPS — set NGINX_CONF=nginx-ssl.conf to enable
# Run: bash scripts/generate-certs.sh   (creates docker/certs/)
NGINX_CONF=nginx-ssl.conf
HTTPS_PORT=3443

# Required secrets for Docker services
POSTGRES_PASSWORD=atlas-vox-pg
REDIS_PASSWORD=atlas-vox-redis
ENCRYPTION_KEY=dev-only-change-in-production-32chars
AUTH_DISABLED=true
APP_ENV=development
JWT_SECRET_KEY=atlas-vox-dev-jwt-secret-key-32ch
